### App / Core
APP_NAME=Fatturino
APP_VERSION=0.0.1
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

### Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

### Maintenance
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

### Security / Runtime
BCRYPT_ROUNDS=12
# PHP_CLI_SERVER_WORKERS=4

### Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

### Database (SQLite default)
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=

### Sessions / Queue / Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

### Redis (optional)
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

### Mail / SMTP infrastructure
# When true, SMTP settings are managed by env and UI editing is disabled.
SMTP_MANAGED_BY_ENV=false
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

### OpenAPI SDI infrastructure
# When true, OpenAPI settings are managed by env and UI editing is disabled.
OPENAPI_MANAGED_BY_ENV=false
OPENAPI_SDI_API_TOKEN=
OPENAPI_SDI_SANDBOX=false
OPENAPI_SDI_COMPANY_SDI_CODE=
OPENAPI_SDI_WEBHOOK_URL=
OPENAPI_SDI_SANDBOX_URL=https://test.sdi.openapi.it
OPENAPI_SDI_PRODUCTION_URL=https://sdi.openapi.it

### Backup infrastructure (Spatie + S3-compatible)
# When true, backup settings are managed by env and local UI/scheduler are disabled.
BACKUP_MANAGED_BY_ENV=false
BACKUP_RUN_AT=02:00
BACKUP_CLEAN_AT=03:30
BACKUP_NAME=${APP_NAME}
BACKUP_ARCHIVE_PASSWORD=
BACKUP_MAIL_TO_ADDRESS=noreply@fatturino.it
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

### Product analytics (optional)
# Frontend PostHog is enabled only when VITE_POSTHOG_KEY is set.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Backend PostHog is enabled only when POSTHOG_API_KEY is set.
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

### Feature flags
DEMO_ENABLED=false
DEMO_RESET_INTERVAL_MINUTES=60

VITE_APP_NAME="${APP_NAME}"
